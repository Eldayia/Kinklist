# Port sur lequel l'application sera accessible sur votre machine hôte
# Le serveur conserve toujours le port 3000 à l'intérieur du conteneur
# Par défaut: 3000
HOST_PORT=3000

# Environnement Node.js
# Valeurs possibles: development, production
# Par défaut: production
NODE_ENV=production

# Durée de conservation des liens partagés (1 à 365 jours, 0 = sans expiration)
SHARE_TTL_DAYS=30

# Origines supplémentaires autorisées, séparées par des virgules
ALLOWED_ORIGINS=https://kink.eldayia.fr

# Jeton long et aléatoire requis pour consulter /api/stats
# Laisser vide désactive complètement cette route
STATS_TOKEN=

# Secret d'au moins 32 caractères pour chiffrer les partages en AES-256-GCM
# Obligatoire en production. Sauvegardez-le : sans lui, les liens sont illisibles.
DATA_ENCRYPTION_KEY=

# Répertoire de stockage (laisser vide pour utiliser ./data)
DATA_DIR=

# Activer uniquement derrière un reverse proxy de confiance
TRUST_PROXY=false
